// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Usaremos SQLite para desarrollo local por simplicidad en la configuración
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  code      String   @unique // Ejemplo: A123 (Admin), E1234 (Estudiante), D123 (Docente)
  password  String
  name      String
  role      String   @default("STUDENT") // "ADMIN", "TEACHER", "STUDENT"
  
  // Relaciones
  coursesTaught Course[]       @relation("TeacherCourses") // Cursos dados por este docente
  enrollments   Enrollment[]   // Estudiantes inscritos en cursos
  backpackItems BackpackItem[] // Items en la mochila del estudiante
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  
  teacherId   String
  teacher     User     @relation("TeacherCourses", fields: [teacherId], references: [id])

  sessions    Session[]
  enrollments Enrollment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Enrollment {
  id        String   @id @default(uuid())
  
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  grade     Float?   // Calificación del estudiante en este curso

  enrolledAt DateTime @default(now())

  @@unique([studentId, courseId])
}

model Session {
  id          String   @id @default(uuid())
  title       String   // Ej: "SESIÓN 1_FEB 11", "General"
  description String?
  order       Int      @default(0) // Para ordenar en el menú

  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  resources   Resource[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resource {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String   // Enlace al material (PDF, Link, etc)
  type        String   // Ej: "PDF", "VIDEO", "LINK"
  
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Elementos de mochila que referencian a este recurso
  backpackItems BackpackItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Representa un recurso guardado por un estudiante en su "Mochila"
model BackpackItem {
  id          String   @id @default(uuid())
  
  studentId   String
  student     User     @relation(fields: [studentId], references: [id])
  
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  
  savedAt     DateTime @default(now())

  // Un estudiante no puede guardar el mismo recurso dos veces
  @@unique([studentId, resourceId])
}
